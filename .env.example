# RPi5 On-Board Environment Configuration
# Copy this to .env and modify as needed

# MQTT Broker (your laptop/cloud server IP)
MQTT_BROKER=192.168.1.100

# MQTT Port
MQTT_PORT=1883

# Robot ID (must match what's registered in the backend)
ROBOT_ID=rover-esp32-001

# UART Settings (ESP32 connection)
UART_DEVICE=/dev/serial0
UART_BAUD=115200

# SLAM Publish Rate (seconds between MQTT messages)
# SLAM processing runs at 20Hz, but publishing is throttled
SLAM_PUBLISH_INTERVAL=1.0
